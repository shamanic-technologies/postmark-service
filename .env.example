# Database (Neon)
POSTMARK_SERVICE_DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Key Service (Postmark token resolution for all apps)
KEY_SERVICE_URL=http://localhost:3001
KEY_SERVICE_API_KEY=your-key-service-api-key

# Authentication (service-to-service)
POSTMARK_SERVICE_API_KEY=shared-secret-for-service-to-service-auth

# Runs Service (run tracking & cost management)
RUNS_SERVICE_URL=http://localhost:3006
RUNS_SERVICE_API_KEY=your-runs-service-api-key

# Email Gateway (Inbound webhook forwarding — RecordType=Inbound)
# postmark-service forwards inbound Postmark webhooks to ${EMAIL_GATEWAY_SERVICE_URL}/inbound/postmark
# with header `x-api-key: ${EMAIL_GATEWAY_SERVICE_API_KEY}`. Both required at boot — fail loud.
EMAIL_GATEWAY_SERVICE_URL=http://localhost:3009
EMAIL_GATEWAY_SERVICE_API_KEY=shared-secret-with-email-gateway

# Server
PORT=3010
