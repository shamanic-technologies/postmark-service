              "description": {
                "type": "string",
                "nullable": true
              },
              "bouncedAt": {
                "type": "string",
                "nullable": true,
                "format": "date-time"
              },
              "email": {
                "type": "string",
                "nullable": true
              }
            },
            "required": [
              "type",
              "typeCode",
              "description",
              "bouncedAt",
              "email"
            ]
          },
          "openings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "receivedAt": {
                  "type": "string",
