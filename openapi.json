                },
                "firstOpen": {
                  "type": "boolean",
                  "nullable": true
                },
                "platform": {
                  "type": "string",
                  "nullable": true
                },
                "readSeconds": {
                  "type": "number",
                  "nullable": true
                },
                "geo": {
                  "nullable": true
                }
              },
              "required": [
                "receivedAt",
                "firstOpen",
                "platform",
                "readSeconds"
              ]
            }
          },
          "clicks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "receivedAt": {
                  "type": "string",
                  "nullable": true
                },
                "originalLink": {
                  "type": "string",
                  "nullable": true
                },
                "clickLocation": {
                  "type": "string",
                  "nullable": true
                },
                "platform": {
                  "type": "string",
                  "nullable": true
                },
                "geo": {
                  "nullable": true
                }
              },
              "required": [
                "receivedAt",
                "originalLink",
                "clickLocation",
                "platform"
              ]
            }
          }
        },
        "required": [
          "messageId",
          "status",
          "sending",
          "delivery",
          "bounce",
          "openings",
          "clicks"
        ]
